# Growth Masala — Environment Variables
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to git

# Anthropic Claude API (for chatbot)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Contact form email notifications
CONTACT_EMAIL=your-email@gmail.com

# Resend API key (for sending emails) — get free key at https://resend.com
RESEND_API_KEY=re_your-key-here

# WhatsApp number (with country code, no + sign)
NEXT_PUBLIC_WHATSAPP_NUMBER=91XXXXXXXXXX

# Site URL (for SEO and sitemap)
NEXT_PUBLIC_SITE_URL=https://growthmasala.com
