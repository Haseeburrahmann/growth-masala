# Growth Masala — Environment Variables
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to git

# Anthropic Claude API (for chatbot)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Contact form email (Gmail + Nodemailer)
# Generate an App Password: Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=growthmasala@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
CONTACT_EMAIL=growthmasala@gmail.com

# WhatsApp number (with country code, no + sign)
NEXT_PUBLIC_WHATSAPP_NUMBER=91XXXXXXXXXX

# Site URL (for SEO and sitemap)
NEXT_PUBLIC_SITE_URL=https://growthmasala.com
